<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- API 27+ variant: adds windowLightNavigationBar (attribute doesn't
         exist before 27). Keep in sync with values/styles.xml. -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:statusBarColor">@color/resonancePaper</item>
        <item name="android:navigationBarColor">@color/resonancePaper</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
