NEXT_PUBLIC_ENABLE_PHONE_OTP=false

# Canonical site origin for Open Graph / Twitter share links + the PWA manifest.
# Set this to your production domain when you have one. If unset, production
# falls back to Vercel's VERCEL_PROJECT_PRODUCTION_URL, and local dev to
# http://localhost:3000. No trailing slash.
NEXT_PUBLIC_SITE_URL=

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SESSION_COOKIE_NAME=__session
FIREBASE_SESSION_EXPIRES_IN_DAYS=7

R2_ACCOUNT_ID=
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_API_TOKEN=
R2_PUBLIC_BASE=

# OpenAI — slug translation (LLM) + story image generation (Image model)
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_IMAGE_MODEL=gpt-image-2

# Recommendation engine (all optional — sensible defaults shown).
# Write-time: embeds the insight signature; read-time: cheap batch rerank.
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_RERANK_MODEL=gpt-5.4-mini-2026-03-17
# Vector backend behind the IVectorStore abstraction (firestore | future: vectorize).
RECO_VECTOR_BACKEND=firestore
