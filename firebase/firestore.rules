rules_version = '2';

// Resonance — client-direct Firestore access.
// Update this file then deploy via `firebase deploy --only firestore:rules`.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function connectedTo(userId) {
      return signedIn()
        && exists(/databases/$(database)/documents/connections/$(request.auth.uid < userId ? request.auth.uid + "_" + userId : userId + "_" + request.auth.uid));
    }

    function cardVisible(data) {
      return data.visibility == "public"
        || (
          signedIn()
          && (
            data.authorId == request.auth.uid
            || (data.visibility == "connections" && connectedTo(data.authorId))
          )
        );
    }

    function authorOnlyMetricsUnchanged() {
      return request.resource.data.readCount == resource.data.readCount
        && request.resource.data.resonanceCount == resource.data.resonanceCount
        && request.resource.data.inviteCount == resource.data.inviteCount;
    }

    // --- users ---
    // Profiles are public on this storytelling platform (author bylines, public
    // profile pages, and feeds are viewable by logged-out visitors). Firestore
    // rules cannot redact individual fields, so the user doc must hold no
    // secret: phoneHash is forced to "" on create (below) and any real PII must
    // live in a separate owner-only doc/subcollection if ever added.
    match /users/{userId} {
      allow create: if isSelf(userId)
        && request.resource.data.phoneHash == ""
        && request.resource.data.handleLower == request.resource.data.handle.lower();
      allow get: if true;
      // List is required for handle uniqueness checks and public profile lookups
      // (where handleLower == ?).
      allow list: if true;
      allow update: if isSelf(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "handle",
          "handleLower",
          "bio",
          "region",
          "primaryLocale",
          "autoTranslateTo",
          "avatarSeed",
          "avatarUrl",
          "initials",
          "accentColor",
          "handleChangedAt"
        ]);
      allow delete: if false;
    }

    // --- cards ---
    // Reads are governed by visibility. Writes are author-only and cannot
    // tamper with metrics that are aggregated by trusted writers.
    match /cards/{cardId} {
      allow get: if cardVisible(resource.data);
      // Anonymous visitors may only list public cards (the feed query filters
      // visibility == "public", so every candidate doc passes). Signed-in users
      // may run author-scoped list queries that also surface their own
      // private/connections cards.
      allow list: if signedIn() || resource.data.visibility == "public";
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.keys().hasAll(["authorId", "thoughtCore", "story", "tags", "visibility"])
        && request.resource.data.readCount == 0
        && request.resource.data.resonanceCount == 0
        && request.resource.data.inviteCount == 0;
      allow update: if signedIn()
        && resource.data.authorId == request.auth.uid
        && authorOnlyMetricsUnchanged();
      allow delete: if signedIn()
        && resource.data.authorId == request.auth.uid
        && resource.data.publishedAt == null;
    }

    // --- connections ---
    // Either party may create the connection atomically when accepting an
    // invite. The doc id is deterministic: min(uidA, uidB) + "_" + max(...).
    // Rules require the caller is one of the two parties and that both
    // members are present.
    function sortedConnectionId(a, b) {
      return a < b ? a + "_" + b : b + "_" + a;
    }
    match /connections/{connectionId} {
      allow read: if signedIn() && request.auth.uid in resource.data.userIds;
      allow create: if signedIn()
        && request.resource.data.userIds is list
        && request.resource.data.userIds.size() == 2
        && request.auth.uid in request.resource.data.userIds
        && connectionId == sortedConnectionId(
            request.resource.data.userIds[0],
            request.resource.data.userIds[1]
          );
      allow update: if signedIn()
        && request.auth.uid in resource.data.userIds
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["muted"]);
      allow delete: if false;
    }

    // --- invites ---
    // Sender creates; sender/recipient can read and update status.
    // The daily quota is enforced separately via /quotas (see below).
    match /invites/{inviteId} {
      allow read: if signedIn()
        && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.status == "pending";
      allow update: if signedIn()
        && (
          resource.data.fromUserId == request.auth.uid
          || resource.data.toUserId == request.auth.uid
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"]);
      allow delete: if false;
    }

    // --- resonances ---
    // Doc ID convention: {cardId}_{userId} so toggling is idempotent and
    // only the resonator can read/write their own record.
    match /resonances/{resonanceId} {
      // The resonator reads their own record; the card's author may also read
      // every resonance on their card (to render the resonator avatar group).
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid
        || get(/databases/$(database)/documents/cards/$(resource.data.cardId)).data.authorId == request.auth.uid
      );
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && resonanceId == request.resource.data.cardId + "_" + request.auth.uid;
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // --- cardLinks ---
    // A public association from one of the viewer's own cards to a target card.
    // Doc id is deterministic: {sourceCardId}_{targetCardId} (idempotent).
    match /cardLinks/{linkId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.sourceAuthorId == request.auth.uid
        && linkId == request.resource.data.sourceCardId + "_" + request.resource.data.targetCardId
        && get(/databases/$(database)/documents/cards/$(request.resource.data.sourceCardId)).data.authorId == request.auth.uid;
      allow update: if false;
      allow delete: if signedIn() && resource.data.sourceAuthorId == request.auth.uid;
    }

    // --- notifications ---
    // Recipients can read and mark their own notifications read.
    // Limited client-create is allowed for events the sender already has
    // permission to perform (e.g. inviting someone, marking a resonance):
    //   * type == "invite"             -> payload.fromUserId == auth.uid
    //   * type == "resonance_summary"  -> created by trusted writer only
    //   * type == "translation_done"   -> created by trusted writer only
    function notificationIsInviteSender() {
      return request.resource.data.type == "invite"
        && request.resource.data.payload.fromUserId == request.auth.uid
        && request.resource.data.userId != request.auth.uid;
    }
    // Interaction notifications (resonance / comment / card_link): the actor
    // creates a notification addressed to someone else, stamped with their uid.
    function actorNotif(type) {
      return request.resource.data.type == type
        && request.resource.data.payload.fromUserId == request.auth.uid
        && request.resource.data.userId != request.auth.uid;
    }
    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.readAt == null
        && (
          notificationIsInviteSender()
          || actorNotif("resonance")
          || actorNotif("card_link")
        );
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readAt"]);
      allow delete: if false;
    }

    // --- quotas ---
    // Doc ID convention: {userId}_{YYYY-MM-DD}. The owner may increment their
    // own counter via a transaction, and rules cap it at 3 per day.
    match /quotas/{quotaId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.inviteCount <= 3;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.inviteCount <= 3
        && request.resource.data.inviteCount >= resource.data.inviteCount;
      allow delete: if false;
    }
  }
}
